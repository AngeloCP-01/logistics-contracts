{
  "name": "@angelocp-01/logistics-contracts",
  "version": "0.3.0",
  "description": "Inter-service contracts for the AI Logistics Platform (TypeScript types + JSON Schemas).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "schemas/"
  ],
  "scripts": {
    "prebuild": "rm -rf dist schemas",
    "build": "tsc && mkdir -p schemas && cp ../../schemas/*.json schemas/",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelocp-01/logistics-contracts.git",
    "directory": "packages/node"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
